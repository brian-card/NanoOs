#!/bin/bash

set -e

hostname="${1}"
filesystem="fat32"
imageSizeMB=100
partitionOffsetMB=2
blocksPerOverlay=16

if [ "${hostname}" = "" ]; then
	echo "Usage ${0} <hostname>" >&2
	exit 1
fi

imageFile="$(mktemp)"

cleanup() {
	rm -f "${imageFile}"
}
trap cleanup ERR EXIT

dd if=/dev/zero of="${imageFile}" bs=1M count=${imageSizeMB} status=progress

echo "Building applications..."
make -j $(nproc) -C usr/src clean
make -j $(nproc) -C usr/src COMPILE=gcc LINK=ld OBJCOPY=objcopy \
	OBJDUMP=objdump SIZE=size LINKER_SCRIPT=NanoOsSim.ld overlays
make -j $(nproc) -C sim clean
make -j $(nproc) -C sim

echo ""
echo "Build complete."

# Partition: MBR, FAT32 (partition type 0xc) starting at 2 MiB.
# sfdisk is used instead of parted because parted truncates image files
# to the minimum size needed for the partition table, discarding the
# pre-allocated space from dd.
echo "${partitionOffsetMB}MiB,+,c" | sfdisk "${imageFile}"

# Partition offset and size in 512-byte sectors, which mformat needs to
# correctly populate the BPB (BIOS Parameter Block) in the FAT32 boot sector.
# The byte offset is computed explicitly (rather than using @@2M) to avoid
# mtools interpreting 'M' as SI megabytes (1,000,000) instead of binary
# mebibytes (1,048,576), which would misalign reads/writes vs. sfdisk.
partitionOffsetBytes=$(( partitionOffsetMB * 1024 * 1024 ))
partitionOffsetSectors=$(( partitionOffsetBytes / 512 ))
partitionSectors=$(( imageSizeMB * 1024 * 1024 / 512 - partitionOffsetSectors ))

# Format and populate the FAT32 partition at the 2 MiB offset.
fatImage="${imageFile}@@${partitionOffsetBytes}"

MTOOLS_SKIP_CHECK=1 mformat -i "${fatImage}" -F -c ${blocksPerOverlay} \
	-T ${partitionSectors} -v NanoOs ::
MTOOLS_SKIP_CHECK=1 mmd -i "${fatImage}" ::/usr
MTOOLS_SKIP_CHECK=1 mcopy -i "${fatImage}" -s usr/bin ::/usr/bin
MTOOLS_SKIP_CHECK=1 mcopy -i "${fatImage}" -s usr/lib ::/usr/lib
MTOOLS_SKIP_CHECK=1 mmd -i "${fatImage}" ::/etc
printf '%s' "${hostname}" \
	| MTOOLS_SKIP_CHECK=1 mcopy -i "${fatImage}" - ::/etc/hostname
printf '\\s \\r \\n \\l\n\n' \
	| MTOOLS_SKIP_CHECK=1 mcopy -i "${fatImage}" - ::/etc/issue

# Write block overlays into the image at their absolute sector positions,
# relative to the start of the image. Overlay IDs start at 1 to avoid
# colliding with the MBR at sector 0.
blockOverlays="$(ls usr/lib/{filesystem,${filesystem}}/*)"
for blockOverlay in ${blockOverlays}; do
	overlayId="$(basename "${blockOverlay}" .overlay)"
	startBlock=$(( (overlayId * blocksPerOverlay) + 1 ))
	dd if="${blockOverlay}" of="${imageFile}" bs=512 seek=${startBlock} conv=notrunc
done

sim/bin/nano-os-sim "${imageFile}"
